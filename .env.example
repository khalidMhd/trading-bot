PORT=3000

# Polling interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000

# --- Local Windows (broker-exact prices) ---
USE_MT5=true
MT5_SYMBOL=XAUUSD
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# --- Vercel / cloud deploy (set in Vercel dashboard → Environment Variables) ---
# USE_MT5=false
# OANDA_API_TOKEN=          # optional — OANDA practice sandbox (free)
# OANDA_ENV=practice
# TWELVE_DATA_API_KEY=      # optional — Twelve Data free tier

# Without API keys, Yahoo Finance GC=F is used (free, no signup)

# Set to true ONLY for offline UI testing (fake prices)
USE_DEMO=false

# --- Strategy (balanced mode defaults) ---
SIGNAL_THRESHOLD=75
ADX_MIN=22
MIN_CONFLUENCE=5
MIN_EDGE=12

# H1 trend hard block + scoring (set true to include H1; false = M15 only)
USE_H1_FILTER=false
